# GENERATO da ontology/build_mood_ontology.py — non editare a mano.
# Associazione mood -> generi ancorata ai supports_mood osservati in songs.csv.
@prefix ar:   <http://runmaxxin.org/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ar:MoodScheme a skos:ConceptScheme ; rdfs:label "workout mood scheme" .
ar:GenreScheme a skos:ConceptScheme ; rdfs:label "music genre scheme" .

# --- Mood (vocabolario supports_mood) ---
ar:Neutral a ar:Mood, skos:Concept ; rdfs:label "Neutral" ; skos:inScheme ar:MoodScheme .
ar:Focused a ar:Mood, skos:Concept ; rdfs:label "Focused" ; skos:inScheme ar:MoodScheme .
ar:Energetic a ar:Mood, skos:Concept ; rdfs:label "Energetic" ; skos:inScheme ar:MoodScheme .
ar:Motivated a ar:Mood, skos:Concept ; rdfs:label "Motivated" ; skos:inScheme ar:MoodScheme .
ar:Calm a ar:Mood, skos:Concept ; rdfs:label "Calm" ; skos:inScheme ar:MoodScheme .

# --- Generi (foglia) con affinita' di mood osservata ---
ar:g_acoustic a ar:Genre, skos:Concept ; rdfs:label "acoustic" ; skos:inScheme ar:GenreScheme ; ar:dominantMood ar:Neutral ; ar:genreSuitsMood ar:Neutral , ar:Focused .
ar:g_afrobeat a ar:Genre, skos:Concept ; rdfs:label "afrobeat" ; skos:inScheme ar:GenreScheme ; ar:dominantMood ar:Motivated ; ar:genreSuitsMood ar:Focused , ar:Motivated .
ar:g_alt_rock a ar:Genre, skos:Concept ; rdfs:label "alt-rock" ; skos:inScheme ar:GenreScheme ; ar:dominantMood ar:Neutral ; ar:genreSuitsMood ar:Neutral .
